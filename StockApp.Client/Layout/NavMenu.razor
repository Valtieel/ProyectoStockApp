            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="movimientos">
                📋 Movimientos
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="alertas">
