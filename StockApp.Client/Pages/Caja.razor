@page "/caja"
@inject HttpClient Http

<h3>🏧 Caja</h3>

@if (cargando)
{
    <p>Cargando...</p>
}
else if (cajaActual == null)
{
    <div class="panel">
        <h4>No hay caja abierta</h4>
        <p>Ingresá el monto inicial para abrir la caja del día:</p>
        <div class="campo">
            <label>Monto inicial</label>
            <input type="number" @bind="montoInicial" placeholder="Ej: 5000" />
        </div>
        <button class="btn-abrir" @onclick="AbrirCaja">💵 Abrir Caja</button>
    </div>
}
else
{
    <div class="panel abierta">
        <h4>✅ Caja abierta</h4>
        <div class="info">
            <span>Apertura:</span>
            <strong>@cajaActual.FechaApertura.ToString("dd/MM/yyyy HH:mm")</strong>
        </div>
        <div class="info">
            <span>Monto inicial:</span>
            <strong>$@cajaActual.MontoInicial</strong>
        </div>
        <hr />
        <h4>Cerrar caja</h4>
        <p>Contá el dinero en caja y registrá el monto final:</p>
        <div class="campo">
            <label>Monto final contado</label>
            <input type="number" @bind="montoFinal" placeholder="Ej: 25000" />
        </div>
        <button class="btn-cerrar" @onclick="CerrarCaja">🔒 Cerrar Caja</button>
    </div>
}

@if (resumenCierre != null)
{
    <div class="panel resumen">
        <h4>📊 Resumen del cierre</h4>
        <div class="info">
            <span>Monto inicial:</span>
            <strong>$@resumenCierre.MontoInicial</strong>
        </div>
        <div class="info">
            <span>Total ventas:</span>
            <strong>$@resumenCierre.TotalVentas</strong>
        </div>
        <div class="info">
            <span>Monto esperado:</span>
            <strong>$@resumenCierre.MontoEsperado</strong>
        </div>
        <div class="info">
            <span>Monto real contado:</span>
            <strong>$@resumenCierre.MontoReal</strong>
        </div>
        <div class="info @(resumenCierre.Diferencia == 0 ? "ok" : "diferencia")">
            <span>Diferencia:</span>
            <strong>$@resumenCierre.Diferencia</strong>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(mensaje))
{
    <p class="mensaje">@mensaje</p>
}

@code {
    private CajaDto? cajaActual;
    private ResumenCierre? resumenCierre;
    private decimal montoInicial;
    private decimal montoFinal;
    private bool cargando = true;
    private string mensaje = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await CargarCajaActual();
    }

    private async Task CargarCajaActual()
    {
        cargando = true;
        try
        {
            cajaActual = await Http.GetFromJsonAsync<CajaDto>("cajas/actual");
        }
        catch
        {
            cajaActual = null;
        }
        cargando = false;
    }

    private async Task AbrirCaja()
    {
        await Http.PostAsJsonAsync("cajas/abrir", montoInicial);
        mensaje = "✅ Caja abierta correctamente.";
        await CargarCajaActual();
    }

    private async Task CerrarCaja()
    {
        var response = await Http.PostAsJsonAsync("cajas/cerrar", montoFinal);
        resumenCierre = await response.Content.ReadFromJsonAsync<ResumenCierre>();
        mensaje = "🔒 Caja cerrada correctamente.";
        cajaActual = null;
    }

    public class CajaDto
    {
        public int Id { get; set; }
        public decimal MontoInicial { get; set; }
        public DateTime FechaApertura { get; set; }
        public bool Abierta { get; set; }
    }

    public class ResumenCierre
    {
        public decimal MontoInicial { get; set; }
        public decimal TotalVentas { get; set; }
        public decimal MontoEsperado { get; set; }
        public decimal MontoReal { get; set; }
        public decimal Diferencia { get; set; }
    }
}

<style>
    h3 { margin-bottom: 1rem; }

    .panel {
        background: #f9f9f9;
        border: 1px solid #ddd;
        border-radius: 10px;
        padding: 1.5rem;
        max-width: 500px;
        margin-bottom: 1.5rem;
    }

    .abierta { border-color: #2ecc71; border-width: 2px; }
    .resumen { border-color: #3498db; border-width: 2px; }

    .campo {
        margin-bottom: 0.8rem;
        display: flex;
        flex-direction: column;
    }

    .campo label {
        font-weight: 600;
        margin-bottom: 4px;
        font-size: 14px;
    }

    .campo input {
        padding: 8px;
        border: 1px solid #ccc;
        border-radius: 6px;
        font-size: 15px;
    }

    .info {
        display: flex;
        justify-content: space-between;
        padding: 6px 0;
        border-bottom: 1px solid #eee;
        font-size: 15px;
    }

    .ok strong { color: #27ae60; }
    .diferencia strong { color: #e74c3c; }

    .btn-abrir {
        background-color: #2ecc71;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-size: 15px;
        cursor: pointer;
        margin-top: 0.5rem;
    }

    .btn-cerrar {
        background-color: #e74c3c;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-size: 15px;
        cursor: pointer;
        margin-top: 0.5rem;
    }

    .mensaje {
        font-weight: 600;
        color: #27ae60;
        margin-top: 1rem;
    }
</style>