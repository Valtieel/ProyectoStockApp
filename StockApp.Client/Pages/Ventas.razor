    }

    .btn-cobrar {
        background-color: #2ecc71;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 8px;
        font-size: 18px;
        cursor: pointer;
        width: 100%;
    }

    .alerta {
        color: #e67e22;
        font-weight: 600;
    }

    .mensaje {
        font-weight: 600;
        color: #27ae60;
        margin-top: 1rem;
    }
</style>